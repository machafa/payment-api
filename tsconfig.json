{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src", 
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx", 
    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "jest.config.js", "src/migration.ts", "src/tests"],
  "exclude": ["node_modules", "dist"]
}