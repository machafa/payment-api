{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["node", "jest"]
  },
  "include": [
    "src/**/*", 
    "app/**/*", 
    "jest.config.js", 
    "src/migration.ts", 
    "src/tests"
  ],
  "exclude": ["node_modules", "dist"]
}